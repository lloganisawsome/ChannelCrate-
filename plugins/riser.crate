    "createdAt": "2026-07-17T00:00:00.000Z",
    "preview": {
      "iconType": "plugin",
      "iconPath": "assets/crate-icons/plugin.png",
      "label": "Riser Sweep",
      "detail": "Motion add-on"
    },
    "summary": "Install Riser Sweep as a ChannelCrate plugin."
