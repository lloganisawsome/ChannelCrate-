{
  "manifest": {
    "format": "channelcrate.crate",
    "formatVersion": 1,
    "app": "ChannelCrate",
    "appVersion": "0.1.0",
    "name": "Shimmer Wash Plugin",
    "crateType": "plugin",
    "createdAt": "2026-07-17T00:00:00.000Z",
    "preview": {
      "iconType": "plugin",
      "iconPath": "assets/crate-icons/plugin.png",
      "label": "Shimmer Wash",
      "detail": "Space add-on"
    },
    "summary": "Install Shimmer Wash as a ChannelCrate plugin."
  },
  "contents": {
    "pluginApi": "channelcrate.plugin.v1",
    "installMode": "add-on",
    "communityStoreReady": true,
    "plugins": [
      {
        "id": "shimmer",
        "name": "Shimmer Wash",
        "short": "SHIM",
        "engine": "space",
        "category": "Space",
        "target": "deck",
        "windowMode": "separate",
        "state": {
          "active": false,
          "amount": 0
        }
      }
    ]
  }
}