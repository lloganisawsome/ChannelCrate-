{
  "manifest": {
    "format": "channelcrate.crate",
    "formatVersion": 1,
    "app": "ChannelCrate",
    "appVersion": "0.1.0",
    "name": "Stereo Flip Plugin",
    "crateType": "plugin",
    "createdAt": "2026-07-17T00:00:00.000Z",
    "preview": {
      "iconType": "plugin",
      "iconPath": "assets/crate-icons/plugin.png",
      "label": "Stereo Flip",
      "detail": "Stereo add-on"
    },
    "summary": "Install Stereo Flip as a ChannelCrate plugin."
  },
  "contents": {
    "pluginApi": "channelcrate.plugin.v1",
    "installMode": "add-on",
    "communityStoreReady": true,
    "plugins": [
      {
        "id": "stereoflip",
        "name": "Stereo Flip",
        "short": "FLIP",
        "engine": "width",
        "category": "Stereo",
        "target": "deck",
        "windowMode": "separate",
        "state": {
          "active": false,
          "amount": 0
        }
      }
    ]
  }
}