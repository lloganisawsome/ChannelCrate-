{
  "manifest": {
    "format": "channelcrate.crate",
    "formatVersion": 1,
    "app": "ChannelCrate",
    "appVersion": "0.1.0",
    "name": "Vinyl Drift Plugin",
    "crateType": "plugin",
    "createdAt": "2026-07-17T00:00:00.000Z",
    "preview": {
      "iconType": "plugin",
      "iconPath": "assets/crate-icons/plugin.png",
      "label": "Vinyl Drift",
      "detail": "Lo-Fi add-on"
    },
    "summary": "Install Vinyl Drift as a ChannelCrate plugin."
  },
  "contents": {
    "pluginApi": "channelcrate.plugin.v1",
    "installMode": "add-on",
    "communityStoreReady": true,
    "plugins": [
      {
        "id": "vinyl",
        "name": "Vinyl Drift",
        "short": "VNYL",
        "engine": "vinyl",
        "category": "Lo-Fi",
        "target": "deck",
        "windowMode": "separate",
        "state": {
          "active": false,
          "amount": 0
        }
      }
    ]
  }
}